# =============================================================================
# Lumi — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- OpenAI (used for embeddings + optional therapy chat) ---
OPENAI_API_KEY=sk-...

# --- Anthropic Claude (optional therapy chat provider) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- AI Provider Selection ---
# Which AI provider edge functions use for therapy chat.
# Options: "openai" | "claude"
AI_PROVIDER=openai

# --- Admin ---
ADMIN_SECRET_KEY=generate-a-secure-random-string
